# Copy to .env and fill in. .env is git-ignored — NEVER commit real values.
# Auth is Application Default Credentials: run `gcloud auth application-default login`.
# Do NOT put a service-account key here for local dev.

# ---- GCP project & region ----
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ---- Bronze storage (raw CSV, partitioned by year/month) ----
GCS_BUCKET=your-bronze-bucket-name

# ---- BigQuery ----
# Datasets for the medallion layers. Must match the datasets you create in GCP.
BQ_LOCATION=US
BQ_BRONZE_DATASET=flight_delays_bronze
BQ_SILVER_DATASET=flight_delays_silver
BQ_GOLD_DATASET=flight_delays_gold

# ---- dbt ----
# profiles.yml lives in ./dbt and reads the vars above.
DBT_PROFILES_DIR=./dbt

# ---- CI ONLY (leave blank locally; local uses `gcloud auth ... login`) ----
# Path to a service-account key mounted by CI. Local dev must NOT set this.
# GOOGLE_APPLICATION_CREDENTIALS=
